{
    "swagger": "2.0",
    "info": {
        "description": "Đây là tài liệu API cho hệ thống quản lý Bookmark.",
        "title": "Bookmark Management API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
